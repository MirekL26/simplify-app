# Server configuration (copy to .env and edit)
# cp .env.example .env

# LLM server URLs
SIMPLIFIER_NEMOTRON_URL=http://192.168.0.74:8081/v1/chat/completions
SIMPLIFIER_QWEN_URL=http://192.168.0.74:8082/v1/chat/completions

# API key (if required by your LLM server)
SIMPLIFIER_API_KEY=

# Server
SIMPLIFIER_HOST=0.0.0.0
SIMPLIFIER_PORT=8890

# Limits
MAX_FILE_SIZE_MB=50
MAX_CONCURRENT_TASKS=3

# Directories (defaults: ./uploads, ./saved)
# SIMPLIFIER_UPLOAD_DIR=./uploads
# SIMPLIFIER_SAVE_DIR=./saved
